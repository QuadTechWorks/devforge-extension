{
  "manifest_version": 3,
  "name": "DevForge",
  "version": "1.3.0",
  "description": "DevForge by QuadTechWorks — a side-panel developer toolkit: encode/decode utilities, snippet & token vaults, localhost port switcher, and games.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "DevForge — by QuadTechWorks",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "dt"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Open DevForge side panel"
    }
  },
  "permissions": [
    "sidePanel",
    "storage",
    // "tabs": the Port Switcher reads the active tab's URL to show a
    // "currently on localhost:<port>" banner and to "swap" the current tab to
    // the same path on another port (chrome.tabs.query/update/create). Only the
    // URL is inspected; no page content is read or injected.
    "tabs"
  ]
}
